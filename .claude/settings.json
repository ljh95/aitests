{
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(git:*)",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Read",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/commit-session.sh",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ]
  }
}
